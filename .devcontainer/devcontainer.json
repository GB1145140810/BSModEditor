{
  "name": "ModEditor Development",
  "image": "mcr.microsoft.com/devcontainers/android:latest",
  "features": {
    "ghcr.io/devcontainers/features/java:1": {
      "version": "11"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.vscode-typescript-next",
        "ms-vscode.vscode-java",
        "vscjava.vscode-java-pack"
      ]
    }
  },
  "postCreateCommand": "chmod +x gradlew && ./gradlew assembleDebug",
  "forwardPorts": [8080],
  "remoteUser": "vscode"
}